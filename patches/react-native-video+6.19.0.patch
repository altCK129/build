+    /**
+     * libass-android overlay view. Created when an AssHandler is provided, destroyed when null is
+     * passed. Uses OVERLAY_OPEN_GL mode — rendering happens on a dedicated GL thread so it doesn't
+     * block the UI thread.
+     */
+    private var assSubtitleView: AssSubtitleView? = null
+
+    /**
+     * Called by ReactExoplayerView immediately after the ExoPlayer is created (with a non-null
+     * AssHandler) and immediately before release (with null).
+     */
+    fun setAssHandler(handler: AssHandler?) {
+        // Remove and discard the previous overlay view if any.
+        assSubtitleView?.let { removeView(it) }
+        assSubtitleView = null
+
+        if (handler == null) return
+
+        // Create the AssSubtitleView overlay and add it on top of everything.
+        // Note: we do NOT call subtitleView.withAssSupport(handler) here — that extension
+        // would add AssSubtitleView inside PlayerView's content frame (wrong parent for
+        // OVERLAY_OPEN_GL mode, and would move with the video on resize).
+        // AssSubtitleView self-registers its videoTimeCallback in onAttachedToWindow.
+        val view = AssSubtitleView(context, handler)
+        view.layoutParams = LayoutParams(LayoutParams.MATCH_PARENT, LayoutParams.MATCH_PARENT)
+        addView(view)
+        assSubtitleView = view
+    }
